HUBSPOT_API_TOKEN=your-hubspot-private-app-token-here
NOTION_API_TOKEN=your-notion-integration-token-here
NOTION_PARTNER_MEETING_DATABASE_ID=cb96551db62b4d6f9eaa05f50995e9d7
NOTION_PARTNER_MEETING_DATA_SOURCE_ID=8115f0ee00c8488aa05b57726af0acf4
# Neon Postgres — onboarding step-toggle event log (Primary Care Tech Overview dashboard)
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# Google SSO for the dashboard (Phase 3 / Netlify). Set BOTH as Netlify env vars:
#   VITE_GOOGLE_CLIENT_ID — build-time, gates the frontend to @suvera.co.uk
#   GOOGLE_CLIENT_ID      — runtime, the Netlify Function verifies the ID token
# Leave unset locally → dashboard runs open (name field for changed_by).
VITE_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
